# Backend API base URL (e.g. https://api.primedclinic.com.au)
REACT_APP_URL=

# Backend API base URL when running on port 8443 (optional)
REACT_APP_URL_8443=

# sessionStorage key used to persist survey progress
REACT_APP_SURVEY_LOCAL_STORAGE_KEY=healthQuestionnaire

# Set to "true" to redirect unauthenticated users to /admin/login
REACT_APP_REQUIRE_AUTH=false
